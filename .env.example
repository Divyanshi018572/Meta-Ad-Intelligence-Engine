# ── Meta Ad Performance Analysis — Environment Variables ─────────────────────
# Copy this file and rename it to .env
# Never push .env to GitHub — it is already in .gitignore

# ── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development           # development or production
APP_DEBUG=True
APP_PORT=8501

# ── Data Settings ────────────────────────────────────────────────────────────
DATA_DIR=data/raw
PROCESSED_DIR=data/processed
OUTPUT_DIR=outputs

# ── Streamlit Settings ───────────────────────────────────────────────────────
STREAMLIT_THEME=dark
STREAMLIT_MAX_UPLOAD_SIZE=500

# ── ML Settings ──────────────────────────────────────────────────────────────
RANDOM_STATE=42
TEST_SIZE=0.2
N_CLUSTERS=5

# ── Business Settings ────────────────────────────────────────────────────────
AVG_ORDER_VALUE=85
TARGET_ROAS=3.0
TARGET_CPA=50.0
